# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# База данных
DATABASE_URL="file:./dev.db"

# Режим тестирования (показывает все чек-листы без фильтра по времени)
TEST_MODE=false

# OpenAI API ключ для AI-проверки фото
OPENAI_API_KEY=

# ID администраторов (через запятую)
ADMIN_IDS=
OWNER_ID=

# ID менеджеров для уведомлений (через запятую)
MANAGER_IDS_RESTAURANT=
MANAGER_IDS_CAFE=

# Google Drive (загрузка фото)
ENABLE_GOOGLE_DRIVE=false
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# Google Sheets (прямая запись данных)
GOOGLE_SHEETS_ID=
